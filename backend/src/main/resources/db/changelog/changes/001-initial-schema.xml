<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-permissions" author="iman">
        <createTable tableName="permissions">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="code" type="VARCHAR(100)"><constraints nullable="false" unique="true"/></column>
            <column name="name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="module" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="002-roles" author="iman">
        <createTable tableName="roles">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="name" type="VARCHAR(50)"><constraints nullable="false" unique="true"/></column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="role_permissions">
            <column name="role_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_role_permissions_role" references="roles(id)"/></column>
            <column name="permission_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_role_permissions_permission" references="permissions(id)"/></column>
        </createTable>
        <addPrimaryKey tableName="role_permissions" columnNames="role_id, permission_id"/>
    </changeSet>

    <changeSet id="003-users" author="iman">
        <createTable tableName="users">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="email" type="VARCHAR(100)"><constraints nullable="false" unique="true"/></column>
            <column name="password" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="first_name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="last_name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="avatar_url" type="VARCHAR(500)"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="user_roles">
            <column name="user_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_user_roles_user" references="users(id)"/></column>
            <column name="role_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_user_roles_role" references="roles(id)"/></column>
        </createTable>
        <addPrimaryKey tableName="user_roles" columnNames="user_id, role_id"/>
        <createIndex tableName="users" indexName="idx_users_email"><column name="email"/></createIndex>
    </changeSet>

    <changeSet id="004-business-plans" author="iman">
        <createTable tableName="business_plans">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="founder_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="founder_position" type="VARCHAR(100)"/>
            <column name="founder_email" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="founder_phone" type="VARCHAR(50)"/>
            <column name="country" type="VARCHAR(100)"/>
            <column name="linkedin_url" type="VARCHAR(500)"/>
            <column name="website" type="VARCHAR(500)"/>
            <column name="company_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="industry" type="VARCHAR(100)"/>
            <column name="stage" type="VARCHAR(50)"/>
            <column name="team_size" type="INTEGER"/>
            <column name="founded_date" type="DATE"/>
            <column name="funding_amount" type="DECIMAL(19,2)"/>
            <column name="revenue" type="DECIMAL(19,2)"/>
            <column name="monthly_growth" type="DECIMAL(10,2)"/>
            <column name="company_description" type="TEXT"/>
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT"><constraints nullable="false"/></column>
            <column name="current_step" type="INTEGER" defaultValueNumeric="1"/>
            <column name="assigned_to_id" type="UUID"><constraints foreignKeyName="fk_bp_assigned_to" references="users(id)"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="business_plans" indexName="idx_bp_status"><column name="status"/></createIndex>
        <createIndex tableName="business_plans" indexName="idx_bp_email"><column name="founder_email"/></createIndex>
    </changeSet>

    <changeSet id="005-bp-documents-notes-history" author="iman">
        <createTable tableName="business_plan_documents">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="business_plan_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_bpd_bp" references="business_plans(id)"/></column>
            <column name="file_name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="original_name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="file_path" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="file_type" type="VARCHAR(50)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="business_plan_notes">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="business_plan_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_bpn_bp" references="business_plans(id)"/></column>
            <column name="author_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_bpn_author" references="users(id)"/></column>
            <column name="content" type="TEXT"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="business_plan_history">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="business_plan_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_bph_bp" references="business_plans(id)"/></column>
            <column name="from_status" type="VARCHAR(20)"/>
            <column name="to_status" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="changed_by_id" type="UUID"><constraints foreignKeyName="fk_bph_changed_by" references="users(id)"/></column>
            <column name="comment" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="006-jobs-applicants" author="iman">
        <createTable tableName="jobs">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="title" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="department" type="VARCHAR(100)"/>
            <column name="location" type="VARCHAR(100)"/>
            <column name="type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"/>
            <column name="responsibilities" type="TEXT"/>
            <column name="requirements" type="TEXT"/>
            <column name="benefits" type="TEXT"/>
            <column name="experience" type="VARCHAR(100)"/>
            <column name="education" type="VARCHAR(100)"/>
            <column name="salary_min" type="DECIMAL(19,2)"/>
            <column name="salary_max" type="DECIMAL(19,2)"/>
            <column name="meta_title" type="VARCHAR(200)"/>
            <column name="meta_description" type="VARCHAR(500)"/>
            <column name="slug" type="VARCHAR(200)"><constraints unique="true"/></column>
            <column name="date_posted" type="DATE"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="jobs" indexName="idx_jobs_status"><column name="status"/></createIndex>
        <createIndex tableName="jobs" indexName="idx_jobs_slug"><column name="slug"/></createIndex>
        <createTable tableName="applicants">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="job_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_applicant_job" references="jobs(id)"/></column>
            <column name="first_name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="last_name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="email" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="linkedin_url" type="VARCHAR(500)"/>
            <column name="cover_letter" type="TEXT"/>
            <column name="resume_path" type="VARCHAR(500)"/>
            <column name="resume_name" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="NEW"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="applicants" indexName="idx_applicants_status"><column name="status"/></createIndex>
        <createIndex tableName="applicants" indexName="idx_applicants_job"><column name="job_id"/></createIndex>
    </changeSet>

    <changeSet id="007-applicant-notes-activities" author="iman">
        <createTable tableName="applicant_notes">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="applicant_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_an_applicant" references="applicants(id)"/></column>
            <column name="author_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_an_author" references="users(id)"/></column>
            <column name="content" type="TEXT"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="applicant_activities">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="applicant_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_aa_applicant" references="applicants(id)"/></column>
            <column name="from_status" type="VARCHAR(20)"/>
            <column name="to_status" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="changed_by_id" type="UUID"><constraints foreignKeyName="fk_aa_changed_by" references="users(id)"/></column>
            <column name="comment" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="008-portfolio-cms-insights-team" author="iman">
        <createTable tableName="portfolio_companies">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="industry" type="VARCHAR(100)"/>
            <column name="description" type="TEXT"/>
            <column name="image_url" type="VARCHAR(500)"/>
            <column name="website" type="VARCHAR(500)"/>
            <column name="is_featured" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="display_order" type="INTEGER" defaultValueNumeric="0"/>
            <column name="status" type="VARCHAR(20)" defaultValue="PUBLISHED"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="cms_pages">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="title" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="slug" type="VARCHAR(200)"><constraints nullable="false" unique="true"/></column>
            <column name="content" type="TEXT"/>
            <column name="meta_title" type="VARCHAR(200)"/>
            <column name="meta_description" type="VARCHAR(500)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT"><constraints nullable="false"/></column>
            <column name="published_at" type="DATE"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="insights">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="title" type="VARCHAR(300)"><constraints nullable="false"/></column>
            <column name="slug" type="VARCHAR(200)"><constraints nullable="false" unique="true"/></column>
            <column name="excerpt" type="TEXT"/>
            <column name="content" type="TEXT"/>
            <column name="image_url" type="VARCHAR(500)"/>
            <column name="author" type="VARCHAR(100)"/>
            <column name="published_date" type="DATE"/>
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="team_members">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="full_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="role" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="bio" type="TEXT"/>
            <column name="image_url" type="VARCHAR(500)"/>
            <column name="linkedin_url" type="VARCHAR(500)"/>
            <column name="display_order" type="INTEGER" defaultValueNumeric="0"/>
            <column name="status" type="VARCHAR(20)" defaultValue="PUBLISHED"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="009-media-audit-notifications-settings-contact" author="iman">
        <createTable tableName="media_files">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="file_name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="original_name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="file_path" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="media_type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="alt" type="VARCHAR(500)"/>
            <column name="uploaded_by_id" type="UUID"><constraints foreignKeyName="fk_media_uploaded_by" references="users(id)"/></column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="audit_logs">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="user_id" type="UUID"><constraints foreignKeyName="fk_audit_user" references="users(id)"/></column>
            <column name="action" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="module" type="VARCHAR(100)"/>
            <column name="entity_type" type="VARCHAR(100)"/>
            <column name="entity_id" type="VARCHAR(36)"/>
            <column name="details" type="TEXT"/>
            <column name="ip_address" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="audit_logs" indexName="idx_audit_created"><column name="created_at"/></createIndex>
        <createTable tableName="notifications">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="user_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_notification_user" references="users(id)"/></column>
            <column name="title" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="message" type="TEXT"/>
            <column name="type" type="VARCHAR(50)"/>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="link_url" type="VARCHAR(500)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="settings">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="setting_key" type="VARCHAR(100)"><constraints nullable="false" unique="true"/></column>
            <column name="setting_value" type="TEXT"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="category" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
        <createTable tableName="contact_messages">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="email" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="subject" type="VARCHAR(200)"/>
            <column name="message" type="TEXT"><constraints nullable="false"/></column>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

</databaseChangeLog>
