            <column name="created_at" valueComputed="NOW()"/>
            <column name="updated_at" valueComputed="NOW()"/>
        </insert>
        <sql>
            INSERT INTO role_permissions (role_id, permission_id)
            SELECT '22222222-2222-2222-2222-222222222001', id FROM permissions;
            INSERT INTO role_permissions (role_id, permission_id)
            SELECT '22222222-2222-2222-2222-222222222002', id FROM permissions
            WHERE code NOT IN ('roles.manage');
            INSERT INTO role_permissions (role_id, permission_id)
            SELECT '22222222-2222-2222-2222-222222222003', id FROM permissions
            WHERE code IN ('dashboard.view', 'business_plans.manage');
            INSERT INTO role_permissions (role_id, permission_id)
            SELECT '22222222-2222-2222-2222-222222222004', id FROM permissions
            WHERE code IN ('dashboard.view', 'jobs.manage', 'applicants.manage');
        </sql>
