# Copy to a protected deployment-host file (chmod 600). Never commit real values.
# Example:
#   cp deployment/.env.production.example /secure/path/iman-production.env
#   chmod 600 /secure/path/iman-production.env

POSTGRES_DB=iman_investment
POSTGRES_USER=iman_app
POSTGRES_PASSWORD=<generate-a-unique-database-password>

# At least 32 random characters. Required for JWT signing.
JWT_SECRET=<generate-a-cryptographically-random-secret>
JWT_EXPIRATION_MS=3600000

# Exact public site origin(s), no trailing slash. Must match the browser URL.
CORS_ORIGINS=https://investment.example.com

# First-boot admin (created only when no admin user exists). Use a strong password, then change it after login.
ADMIN_INITIAL_EMAIL=admin@imaninvestment.com
ADMIN_INITIAL_PASSWORD=<generate-a-strong-12+-character-password>

# Bind publicly only when host firewall / TLS termination is configured.
# Prefer 127.0.0.1 behind Nginx/Caddy/CLB; use 0.0.0.0 only with care.
HTTP_BIND_ADDRESS=127.0.0.1
HTTP_PORT=8080

# Prefer immutable registry references such as repository@sha256:digest.
# For first Tencent Cloud / single-host deploy you may build locally and omit these
# (compose defaults to iman-investment-backend:local / iman-investment-frontend:local).
BACKEND_IMAGE=registry.example.com/iman/backend:<release-tag>
FRONTEND_IMAGE=registry.example.com/iman/frontend:<release-tag>

# Optional SMTP settings. Leave blank if mail is not enabled yet.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Optional JVM container tuning.
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75 -XX:+ExitOnOutOfMemoryError

# Careers auto-publisher defaults (also editable later in Admin → Jobs / Settings).
# JOB_PUBLISH_ENABLED=true
# JOB_PUBLISH_PER_DAY=2
# JOB_PUBLISH_HOUR=9
# JOB_MAX_OPEN=6
# JOB_AUTO_ROTATE=true
